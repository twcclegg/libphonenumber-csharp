@page "/"
@inject NavigationManager Nav

<PageTitle>libphonenumber-csharp Demo</PageTitle>

<div class="reveal">
<div class="hero">
    <div class="hero__content">
        <span class="hero__eyebrow">
            <span class="wasm-dot" aria-hidden="true"></span>
            Google's libphonenumber, ported to C#
        </span>
        <h1 class="hero__title">Phone numbers, <em>handled.</em></h1>
        <p class="hero__description">
            Parse, format, validate and enrich phone numbers for @(_regionCount)+ regions &mdash;
            running entirely in your browser via WebAssembly. No server, no API calls.
        </p>
        <div class="hero__badges">
            <span class="hero__badge">
                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                NuGet package
            </span>
            <span class="hero__badge">
                <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                @(_regionCount) regions
            </span>
            <span class="hero__badge">
                <svg viewBox="0 0 24 24" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                WebAssembly
            </span>
        </div>
    </div>
</div>

<div class="card">
    <div class="card__header">
        <div class="card__title">Try it now</div>
        <div class="card__subtitle">Enter any phone number for instant parsing, validation and formatting.</div>
    </div>

    <div class="form__row">
        <div class="form__group form__group--flush">
            <label class="form__label" for="home-phone">Phone number</label>
            <input id="home-phone"
                   class="form__input form__input--phone"
                   type="text"
                   value="@_phoneInput"
                   @oninput="OnPhoneInput"
                   @onchange="OnPhoneCommit"
                   placeholder="+1 650 253 0000"
                   autocomplete="tel" />
        </div>
        <div class="form__group form__group--flush">
            <label class="form__label" for="home-region">Default region</label>
            <select id="home-region" class="form__select" @onchange="OnRegionChange">
                @foreach (var r in _regions)
                {
                    <option value="@r.Code" selected="@(r.Code == _selectedRegion)">@r.Display</option>
                }
            </select>
        </div>
    </div>

    @if (_parseError != null)
    {
        <div class="error-message" role="alert">@_parseError</div>
    }
    else if (_parsed != null)
    {
        <div class="result-grid mt-2 reveal" aria-live="polite">
            <div class="result-grid__item">
                <div class="result-grid__label">International</div>
                <div class="result-grid__value result-grid__value--mono">@_phoneUtil.Format(_parsed, PhoneNumberFormat.INTERNATIONAL)</div>
            </div>
            <div class="result-grid__item">
                <div class="result-grid__label">E.164</div>
                <div class="result-grid__value result-grid__value--mono">@_phoneUtil.Format(_parsed, PhoneNumberFormat.E164)</div>
            </div>
            <div class="result-grid__item">
                <div class="result-grid__label">Valid</div>
                <div class="result-grid__value">
                    @if (_phoneUtil.IsValidNumber(_parsed))
                    {
                        <span class="badge badge--success">Valid</span>
                    }
                    else
                    {
                        <span class="badge badge--error">Invalid</span>
                    }
                </div>
            </div>
            <div class="result-grid__item">
                <div class="result-grid__label">Number type</div>
                <div class="result-grid__value"><span class="badge badge--info">@FormatType(_phoneUtil.GetNumberType(_parsed))</span></div>
            </div>
            <div class="result-grid__item">
                <div class="result-grid__label">Region</div>
                <div class="result-grid__value">@(_phoneUtil.GetRegionCodeForNumber(_parsed) ?? "Unknown")</div>
            </div>
            <div class="result-grid__item">
                <div class="result-grid__label">Country code</div>
                <div class="result-grid__value result-grid__value--mono">+@_parsed.CountryCode</div>
            </div>
        </div>
    }
</div>

<h2 class="section__title mt-4">Explore features</h2>

<div class="feature-grid">
    <a href="parse" class="feature-grid__card">
        <div class="feature-grid__icon feature-grid__icon--primary" aria-hidden="true">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </div>
        <h3 class="feature-grid__card-title">Parse &amp; Validate</h3>
        <p class="feature-grid__card-description">Parse phone numbers from text, validate them, and inspect every property including type, region, and country code.</p>
        <span class="feature-grid__go" aria-hidden="true"><svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
    </a>
    <a href="format" class="feature-grid__card">
        <div class="feature-grid__icon feature-grid__icon--success" aria-hidden="true">
            <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
        </div>
        <h3 class="feature-grid__card-title">Formatting</h3>
        <p class="feature-grid__card-description">Format numbers as E.164, international, national, RFC 3966, and for out-of-country or mobile dialing.</p>
        <span class="feature-grid__go" aria-hidden="true"><svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
    </a>
    <a href="live" class="feature-grid__card">
        <div class="feature-grid__icon feature-grid__icon--warning" aria-hidden="true">
            <svg viewBox="0 0 24 24"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        </div>
        <h3 class="feature-grid__card-title">Live Formatter</h3>
        <p class="feature-grid__card-description">Type digits and see them formatted in real-time using the as-you-type formatter, just like a phone dialer.</p>
        <span class="feature-grid__go" aria-hidden="true"><svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
    </a>
    <a href="find" class="feature-grid__card">
        <div class="feature-grid__icon feature-grid__icon--pink" aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </div>
        <h3 class="feature-grid__card-title">Find Numbers</h3>
        <p class="feature-grid__card-description">Extract and parse phone numbers embedded in free-form text with configurable matching leniency.</p>
        <span class="feature-grid__go" aria-hidden="true"><svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
    </a>
    <a href="geo" class="feature-grid__card">
        <div class="feature-grid__icon feature-grid__icon--accent" aria-hidden="true">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <h3 class="feature-grid__card-title">Geocoding &amp; Timezone</h3>
        <p class="feature-grid__card-description">Look up geographic descriptions, time zones, and carrier information for any phone number.</p>
        <span class="feature-grid__go" aria-hidden="true"><svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
    </a>
</div>

<div class="card mt-3">
    <div class="card__header">
        <div class="card__title">Install</div>
        <div class="card__subtitle">Add to your .NET project via NuGet.</div>
    </div>
    <div class="install-block">
        <span class="install-block__prompt" aria-hidden="true">$</span>dotnet add package libphonenumber-csharp
    </div>
    <div class="install-block mt-1">
        <span class="install-block__prompt" aria-hidden="true">$</span>dotnet add package libphonenumber-csharp.extensions
    </div>
</div>
</div>

@code {
    private readonly PhoneNumberUtil _phoneUtil = PhoneNumberUtil.GetInstance();
    private string _phoneInput = "+1 650 253 0000";
    private string _selectedRegion = "US";
    private PhoneNumber? _parsed;
    private string? _parseError;
    private List<RegionOption> _regions = new();
    private int _regionCount;

    protected override void OnInitialized()
    {
        var supported = _phoneUtil.GetSupportedRegions();
        _regionCount = supported.Count;
        _regions = supported
            .OrderBy(r => r)
            .Select(r => new RegionOption(r, $"{r} (+{_phoneUtil.GetCountryCodeForRegion(r)})"))
            .ToList();

        var (n, r2) = UrlState.Read(Nav);
        if (n != null) _phoneInput = n;
        if (!string.IsNullOrEmpty(r2)) _selectedRegion = r2;

        TryParse();
    }

    // @oninput keeps the live results in sync on every keystroke, but does NOT touch the URL.
    private void OnPhoneInput(ChangeEventArgs e)
    {
        _phoneInput = e.Value?.ToString() ?? "";
        TryParse();
    }

    // @onchange fires when the field is committed (blur / Enter), so the URL is only
    // rewritten once the user is done typing — never mid-keystroke.
    private void OnPhoneCommit(ChangeEventArgs e)
    {
        _phoneInput = e.Value?.ToString() ?? "";
        TryParse();
        SyncUrl();
    }

    private void OnRegionChange(ChangeEventArgs e)
    {
        _selectedRegion = e.Value?.ToString() ?? "US";
        TryParse();
        SyncUrl();
    }

    private void SyncUrl()
        => Nav.NavigateTo(UrlState.Build(Nav, _phoneInput, _selectedRegion), forceLoad: false, replace: true);

    private void TryParse()
    {
        _parsed = null;
        _parseError = null;
        if (string.IsNullOrWhiteSpace(_phoneInput)) return;
        try
        {
            _parsed = _phoneUtil.Parse(_phoneInput, _selectedRegion);
        }
        catch (NumberParseException ex)
        {
            _parseError = ex.Message;
        }
    }

    private static string FormatType(PhoneNumberType type) => type switch
    {
        PhoneNumberType.FIXED_LINE => "Fixed Line",
        PhoneNumberType.MOBILE => "Mobile",
        PhoneNumberType.FIXED_LINE_OR_MOBILE => "Fixed/Mobile",
        PhoneNumberType.TOLL_FREE => "Toll Free",
        PhoneNumberType.PREMIUM_RATE => "Premium Rate",
        PhoneNumberType.SHARED_COST => "Shared Cost",
        PhoneNumberType.VOIP => "VoIP",
        PhoneNumberType.PERSONAL_NUMBER => "Personal",
        PhoneNumberType.PAGER => "Pager",
        PhoneNumberType.UAN => "UAN",
        PhoneNumberType.VOICEMAIL => "Voicemail",
        _ => "Unknown"
    };

    private record RegionOption(string Code, string Display);
}
