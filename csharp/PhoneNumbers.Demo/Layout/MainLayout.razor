@inherits LayoutComponentBase

<div class="app-layout">
    <button class="sidebar__toggle"
            @onclick="ToggleSidebar"
            aria-label="Toggle navigation"
            aria-expanded="@_sidebarOpen">
        <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>

    @if (_sidebarOpen)
    {
        <div class="sidebar__overlay sidebar__overlay--visible" @onclick="CloseSidebar"></div>
    }

    <nav class="sidebar @(_sidebarOpen ? "sidebar--open" : "")" aria-label="Main navigation">
        <div class="sidebar__header">
            <a href="" class="sidebar__logo">
                <div class="sidebar__logo-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20" aria-hidden="true">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                </div>
                <div>
                    <div class="sidebar__title">libphonenumber</div>
                    <div class="sidebar__subtitle">C# / WebAssembly</div>
                </div>
            </a>
        </div>

        <div class="sidebar__nav">
            <div class="sidebar__section">
                <div class="sidebar__section-title">Overview</div>
                <NavLink href="" class="sidebar__link" ActiveClass="sidebar__link--active" Match="NavLinkMatch.All" @onclick="CloseSidebar">
                    <span class="sidebar__link-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                    </span>
                    Home
                </NavLink>
            </div>

            <div class="sidebar__section">
                <div class="sidebar__section-title">Features</div>
                <NavLink href="parse" class="sidebar__link" ActiveClass="sidebar__link--active" @onclick="CloseSidebar">
                    <span class="sidebar__link-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </span>
                    Parse &amp; Validate
                </NavLink>
                <NavLink href="format" class="sidebar__link" ActiveClass="sidebar__link--active" @onclick="CloseSidebar">
                    <span class="sidebar__link-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    </span>
                    Formatting
                </NavLink>
                <NavLink href="live" class="sidebar__link" ActiveClass="sidebar__link--active" @onclick="CloseSidebar">
                    <span class="sidebar__link-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
                    </span>
                    Live Formatter
                </NavLink>
                <NavLink href="find" class="sidebar__link" ActiveClass="sidebar__link--active" @onclick="CloseSidebar">
                    <span class="sidebar__link-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    </span>
                    Find Numbers
                </NavLink>
                <NavLink href="geo" class="sidebar__link" ActiveClass="sidebar__link--active" @onclick="CloseSidebar">
                    <span class="sidebar__link-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    </span>
                    Geo &amp; Timezone
                </NavLink>
            </div>

            <div class="sidebar__section">
                <div class="sidebar__section-title">Resources</div>
                <a href="https://github.com/twcclegg/libphonenumber-csharp" target="_blank" rel="noopener" class="sidebar__link">
                    <span class="sidebar__link-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                    </span>
                    GitHub
                </a>
                <a href="https://www.nuget.org/packages/libphonenumber-csharp" target="_blank" rel="noopener" class="sidebar__link">
                    <span class="sidebar__link-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
                    </span>
                    NuGet
                </a>
            </div>
        </div>

        <div class="sidebar__footer">
            Running entirely in your browser via WebAssembly
        </div>
    </nav>

    <main class="app-layout__content">
        <div class="app-layout__container">
            @Body
        </div>
    </main>
</div>

@code {
    private bool _sidebarOpen;

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar() => _sidebarOpen = false;
}
